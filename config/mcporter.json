{
  "mcpServers": {
    "vercel-domains": {
      "command": "npx",
      "args": ["-y", "vercel-domains-mcp"],
      "env": {
        "VERCEL_ACCESS_TOKEN": "${VERCEL_ACCESS_TOKEN}"
      }
    },
    "firecrawl": {
      "description": "Firecrawl hosted MCP for authenticated scraping and extraction.",
      "baseUrl": "https://mcp.firecrawl.dev/v2/mcp",
      "headers": {
        "Authorization": "Bearer ${FIRECRAWL_API_KEY}"
      }
    },
    "chrome-devtools": {
      "description": "Attach chrome-devtools-mcp to the live Oracle browser session.",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--browserUrl", "${CHROME_DEVTOOLS_URL}"],
      "lifecycle": "ephemeral"
    },
    "iterm": {
      "command": "/path/to/iterm-mcp/build/index.js"
    },
    "oracle": {
      "description": "Deprecated oracle-mcp stub. MCP is no longer supported in this fork.",
      "command": "node",
      "args": ["../dist/bin/oracle-mcp.js"],
      "root": ".."
    },
    "oracle-local": {
      "description": "Deprecated oracle-mcp stub. MCP is no longer supported in this fork.",
      "command": "node",
      "args": ["../dist/bin/oracle-mcp.js"],
      "root": ".."
    }
  },
  "imports": []
}
